# Production Environment Variables for Railway Deployment
# Copy these to your Railway dashboard under "Variables" tab

# Server Configuration
# Railway automatically provides PORT - use their variable reference
NODE_ENV=production
PORT=${{PORT}}

# Database Configuration
# Railway automatically provides these when you add a MySQL database
# Use Railway's variable references to connect to the database
DB_HOST=${{MYSQL_HOST}}
DB_USER=${{MYSQL_USER}}
DB_PASSWORD=${{MYSQL_PASSWORD}}
DB_NAME=${{MYSQL_DATABASE}}

# JWT Configuration
# IMPORTANT: Generate a strong random secret for production
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_production_jwt_secret_change_this
JWT_EXPIRES_IN=7d

# CORS Configuration
# Set this to your GitHub Pages URL or custom domain
FRONTEND_URL=https://jzane8.github.io

# Optional: Database Connection Pool Settings
# Uncomment and adjust if needed for production
# DB_CONNECTION_LIMIT=10
# DB_QUEUE_LIMIT=0
